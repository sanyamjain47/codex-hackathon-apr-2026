{
  "name": "git-diff-viewer",
  "version": "0.1.1",
  "private": true,
  "description": "Codex plugin scaffold for Git diff review and visualization.",
  "scripts": {
    "dev": "npm run launch",
    "launch": "node scripts/launch-viewer.mjs",
    "dev:viewer": "npm run dev --workspace @git-diff-viewer/app",
    "dev:app": "npm run launch",
    "build": "npm run build --workspace @git-diff-viewer/app",
    "typecheck": "npm run typecheck --workspace @git-diff-viewer/app"
  },
  "workspaces": [
    "viewer"
  ]
}
